# Optional: Add an Anthropic API key to generate real components.
# If absent, the app uses mock (static) responses instead.
ANTHROPIC_API_KEY=

# Required: Secret key used to sign JWT session tokens.
# Use a long, random string in production (e.g. openssl rand -base64 32).
JWT_SECRET=

# SQLite database path (relative to the project root).
DATABASE_URL=file:./prisma/dev.db
